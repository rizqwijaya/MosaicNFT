# Copy to .env and fill. .env is gitignored. Never commit real keys.

# REQUIRED
PRIVATE_KEY=0x...              # deployer key; becomes owner of both contracts + default feeRecipient
SEPOLIA_RPC_URL=https://...    # Sepolia RPC (Alchemy / Infura / etc.)
ETHERSCAN_API_KEY=...          # for --verify

# OPTIONAL (defaults shown)
# FEE_RECIPIENT=0x...          # defaults to deployer address
# MARKETPLACE_FEE_BPS=250      # 2.5%
# COLLECTION_NAME=MosaicNFT
# COLLECTION_SYMBOL=MOSAIC
