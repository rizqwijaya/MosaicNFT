# Copy to .env (local) or set these in the Netlify dashboard (deploy).
# VITE_* vars are exposed to the browser. They are PUBLIC. Do not put secrets here.

# --- Frontend (VITE_*, public) ---

# WalletConnect Cloud project id (cloud.walletconnect.com). Required for
# WalletConnect / mobile wallets; injected wallets (MetaMask) work without it.
VITE_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC for reads/writes (Alchemy/Infura). Optional, falls back to public.
VITE_SEPOLIA_RPC_URL=

# Subgraph query URL (defaults to the deployed Studio endpoint if unset).
VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/1755292/mosaicnft/v0.0.1

# IPFS gateway for resolving ipfs:// (defaults to Pinata gateway).
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# --- Netlify Functions (server-side, SECRET: set in Netlify dashboard only) ---

# Pinata JWT for the IPFS pinning proxy. SERVER-ONLY. Never prefix with VITE_.
PINATA_JWT=
